<p style="color: green"><%= notice %></p>

<% content_for :title, "Books" %>

<h1><%= t (".books") %></h1>

<div id="books" class="index-items">
  <% @books.each do |book| %>
  <div class="index-item">
    <%= render book %>
    <p>
      <%= link_to t(".show"), book %>
    </p>
  </div>
  <% end %>
</div>

<%= link_to t(".new"), new_book_path %>
