<h1>User List</h1>

<div id="users" class="index-items">
  <% @users.each do |user| %>
    <div class="index-item">
      <%= render user %>
      <p>
        <%= link_to "Profile", user_path(user) %>
      </p>
    </div>
  <% end %>  
</div>

<%= paginate @users %>

<%= link_to "Back", :back %> |
<%= link_to t('views.common.back', name: i18n_pluralize(Book.model_name.human.downcase)), books_path %>
