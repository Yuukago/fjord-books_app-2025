<h1><%= t('layout.list', model: User.model_name.human) %></h1>

<div id="users" class="index-items">
  <% @users.each do |user| %>
    <div class="index-item">
      <%= render user %>
      <p>
        <%= link_to t('.profile'), user_path(user) %>
      </p>
    </div>
  <% end %>
</div>

<%= paginate @users %>
